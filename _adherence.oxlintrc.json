{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "app-supabase/**",
              "app/**",
              "assets/team/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "components/navigation/**",
              "components/overlay/**",
              "marketing.js",
              "pwa/**",
              "slides/**",
              "supabase/**",
              "ui_kits/dashboard/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Playfair Display|Libre Franklin|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Playfair Display, Libre Franklin, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AddressChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:address|role|lead|tail|copyable|key|ref|className|style|children)$/]",
        "message": "<AddressChip> doesn't accept that prop. Declared props: address, role, lead, tail, copyable."
      },
      {
        "selector": "JSXOpeningElement[name.name='AddressChip'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:tainted|hop|exchange|mixer|frozen)$/]",
        "message": "<AddressChip> role must be one of 'tainted' | 'hop' | 'exchange' | 'mixer' | 'frozen'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|icon|onClose|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: tone, title, icon, onClose, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|warning|danger|neutral)$/]",
        "message": "<Alert> tone must be one of 'info' | 'success' | 'warning' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AttorneyCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|bio|photo|credentials|href|orientation|key|ref|className|style|children)$/]",
        "message": "<AttorneyCard> doesn't accept that prop. Declared props: name, role, bio, photo, credentials, href, orientation."
      },
      {
        "selector": "JSXOpeningElement[name.name='AttorneyCard'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:portrait|row)$/]",
        "message": "<AttorneyCard> orientation must be one of 'portrait' | 'row'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|tone|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:navy|stone|ink)$/]",
        "message": "<Avatar> tone must be one of 'navy' | 'stone' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|iconLeft|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, size, iconLeft, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|success|danger|warning|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'success' | 'danger' | 'warning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreadcrumbItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<BreadcrumbItem> doesn't accept that prop. Declared props: label, href."
